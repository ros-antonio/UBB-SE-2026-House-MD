<Page
    x:Class="ERManagementSystem.Views.PatientRegistrationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="40,32,40,40">
        <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="20">

            <!-- Title — uses PageTitleTextBlockStyle from Controls.xaml -->
            <TextBlock
                Text="Patient Registration"
                Style="{StaticResource PageTitleTextBlockStyle}"/>

            <!-- Patient ID (CNP) -->
            <StackPanel Spacing="4">
                <TextBlock Text="Patient ID (CNP)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox
                    PlaceholderText="13-digit CNP"
                    Text="{x:Bind ViewModel.PatientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MaxLength="13"/>
                <TextBlock
                    Text="{x:Bind ViewModel.PatientIdError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- First Name -->
            <StackPanel Spacing="4">
                <TextBlock Text="First Name" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox
                    PlaceholderText="Enter first name"
                    Text="{x:Bind ViewModel.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.FirstNameError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- Last Name -->
            <StackPanel Spacing="4">
                <TextBlock Text="Last Name" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox
                    PlaceholderText="Enter last name"
                    Text="{x:Bind ViewModel.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.LastNameError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- Date of Birth -->
            <StackPanel Spacing="4">
                <TextBlock Text="Date of Birth" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <CalendarDatePicker
                    x:Name="DateOfBirthPicker"
                    PlaceholderText="Select date of birth"
                    HorizontalAlignment="Stretch"
                    DateChanged="DateOfBirthPicker_DateChanged"/>
                <TextBlock
                    Text="{x:Bind ViewModel.DateOfBirthError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- Gender -->
            <StackPanel Spacing="4">
                <TextBlock Text="Gender" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox
                    x:Name="GenderComboBox"
                    PlaceholderText="Select gender"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="GenderComboBox_SelectionChanged">
                    <ComboBoxItem Content="Male"   Tag="Male"/>
                    <ComboBoxItem Content="Female" Tag="Female"/>
                </ComboBox>
            </StackPanel>

            <!-- Phone -->
            <StackPanel Spacing="4">
                <TextBlock Text="Phone" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox
                    PlaceholderText="07XXXXXXXX"
                    Text="{x:Bind ViewModel.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    MaxLength="10"/>
                <TextBlock
                    Text="{x:Bind ViewModel.PhoneError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- Emergency Contact -->
            <StackPanel Spacing="4">
                <TextBlock Text="Emergency Contact" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox
                    PlaceholderText="Firstname Lastname - 07XXXXXXXX"
                    Text="{x:Bind ViewModel.EmergencyContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock
                    Text="{x:Bind ViewModel.EmergencyContactError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- Chief Complaint -->
            <StackPanel Spacing="4">
                <TextBlock Text="Chief Complaint" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox
                    PlaceholderText="Describe the main symptom or reason for visit"
                    Text="{x:Bind ViewModel.ChiefComplaint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    MinHeight="80"/>
                <TextBlock
                    Text="{x:Bind ViewModel.ChiefComplaintError, Mode=OneWay}"
                    Foreground="{StaticResource DangerBrush}"
                    FontSize="12"/>
            </StackPanel>

            <!-- Buttons — uses PrimaryButtonStyle and BaseButtonStyle from Controls.xaml -->
            <StackPanel
                Orientation="Horizontal"
                Spacing="12"
                HorizontalAlignment="Right"
                Margin="0,8,0,0">

                <Button
                    Content="Clear"
                    Command="{x:Bind ViewModel.ClearFormCommand}"/>

                <Button
                    Content="Register"
                    Command="{x:Bind ViewModel.RegisterPatientAndVisitCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Page>
