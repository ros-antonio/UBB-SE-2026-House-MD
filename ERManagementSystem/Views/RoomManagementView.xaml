<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ERManagementSystem.Views.RoomManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ERManagementSystem.Views"
    xmlns:helpers="using:ERManagementSystem.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:RoomTypeColorConverter   x:Key="RoomTypeColorConverter"/>
        <helpers:RoomStatusColorConverter x:Key="RoomStatusColorConverter"/>
    </Page.Resources>

    <!-- Outer 2-column grid: left = main content, right = details panel -->
    <Grid ColumnDefinitions="*,320" ColumnSpacing="0">

        <!-- ── LEFT: room management UI ── -->
        <Grid Grid.Column="0"
              RowDefinitions="Auto,Auto,*"
              Padding="32,24,16,32" RowSpacing="20">

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="Room Management" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{x:Bind ViewModel.LoadRoomsCommand}"/>
            </StackPanel>

            <!-- Dashboard stats -->
            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <StackPanel Orientation="Horizontal" Spacing="40">
                    <StackPanel>
                        <TextBlock Text="Total" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalRooms, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Available" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.AvailableCount, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Occupied" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.OccupiedCount, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Cleaning" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.CleaningCount, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- TabView -->
            <TabView Grid.Row="2" TabWidthMode="Equal" IsAddTabButtonVisible="False">

                <!-- Available -->
                <TabViewItem Header="Available Rooms">
                    <ListView ItemsSource="{x:Bind ViewModel.AvailableRooms, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,4">
                                    <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="12">
                                        <Rectangle Grid.Column="0" Width="6" RadiusX="3" RadiusY="3"
                                                   Fill="{Binding Room_Type, Converter={StaticResource RoomTypeColorConverter}}"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Room_Type}" FontWeight="SemiBold"/>
                                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                                <Run Text="Room #"/><Run Text="{Binding Room_ID}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,2"
                                                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}">
                                            <TextBlock Text="available" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </TabViewItem>

                <!-- Occupied -->
                <TabViewItem Header="Occupied Rooms">
                    <Grid RowDefinitions="*,Auto" RowSpacing="12">
                        <ListView Grid.Row="0"
                                  x:Name="OccupiedRoomsList"
                                  ItemsSource="{x:Bind ViewModel.OccupiedRooms, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedOccupiedRoom, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,4">
                                        <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="12">
                                            <Rectangle Grid.Column="0" Width="6" RadiusX="3" RadiusY="3"
                                                       Fill="{Binding Room_Type, Converter={StaticResource RoomTypeColorConverter}}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Room_Type}" FontWeight="SemiBold"/>
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                                    <Run Text="Room #"/><Run Text="{Binding Room_ID}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="2" CornerRadius="4" Padding="8,2"
                                                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                                                <TextBlock Text="occupied" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontSize="12"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Button Grid.Row="1" Content="Mark as Cleaning"
                                Command="{x:Bind ViewModel.MarkRoomAsCleaningCommand}"
                                HorizontalAlignment="Right"/>
                    </Grid>
                </TabViewItem>

                <!-- Cleaning -->
                <TabViewItem Header="Cleaning">
                    <Grid RowDefinitions="*,Auto" RowSpacing="12">
                        <ListView Grid.Row="0"
                                  x:Name="CleaningRoomsList"
                                  ItemsSource="{x:Bind ViewModel.CleaningRooms, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedCleaningRoom, Mode=TwoWay}"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,4">
                                        <Grid ColumnDefinitions="10,*,Auto" ColumnSpacing="12">
                                            <Rectangle Grid.Column="0" Width="6" RadiusX="3" RadiusY="3"
                                                       Fill="{Binding Room_Type, Converter={StaticResource RoomTypeColorConverter}}"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Room_Type}" FontWeight="SemiBold"/>
                                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                                    <Run Text="Room #"/><Run Text="{Binding Room_ID}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Border Grid.Column="2" CornerRadius="4" Padding="8,2"
                                                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}">
                                                <TextBlock Text="cleaning" Foreground="{ThemeResource SystemFillColorCautionBrush}" FontSize="12"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Button Grid.Row="1" Content="Mark Room as Cleaned"
                                Command="{x:Bind ViewModel.MarkRoomAsCleanedCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Right"/>
                    </Grid>
                </TabViewItem>

            </TabView>
        </Grid>

        <!-- ── RIGHT: Visit Details Panel ── -->
        <Border Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0">
            <local:VisitDetailsPanel x:Name="DetailsPanel"
                                     Patient="{x:Bind ViewModel.SelectedPatient, Mode=OneWay}"
                                     Visit="{x:Bind ViewModel.SelectedVisit, Mode=OneWay}"
                                     Triage="{x:Bind ViewModel.SelectedTriage, Mode=OneWay}"/>
        </Border>

    </Grid>
</Page>
