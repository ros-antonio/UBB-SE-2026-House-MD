<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ERManagementSystem.Views.RoomAssignmentView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ERManagementSystem.Views"
    xmlns:helpers="using:ERManagementSystem.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:RoomTypeColorConverter   x:Key="RoomTypeColorConverter"/>
        <helpers:RoomStatusColorConverter x:Key="RoomStatusColorConverter"/>
    </Page.Resources>

    <!-- Outer 2-column grid: left = main content, right = details panel -->
    <Grid ColumnDefinitions="*,320" ColumnSpacing="0">

        <!-- ── LEFT: main assignment UI ── -->
        <Grid Grid.Column="0"
              RowDefinitions="Auto,*,Auto"
              Padding="32,24,16,32" RowSpacing="16">

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="Room Assignment" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Content="Refresh" Command="{x:Bind ViewModel.LoadDataCommand}"/>
            </StackPanel>

            <!-- Two lists side by side -->
            <Grid Grid.Row="1" ColumnDefinitions="*,1,*" ColumnSpacing="16">

                <!-- Waiting visits -->
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="Waiting for Room" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Ordered by triage level then arrival time"
                               Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ListView x:Name="WaitingVisitsList"
                              ItemsSource="{x:Bind ViewModel.WaitingVisits, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedVisit, Mode=TwoWay}"
                              SelectionMode="Single" MinHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,4">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="Visit #"/><Run Text="{Binding Visit_ID}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Chief_Complaint}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                            <Run Text="Arrived: "/><Run Text="{Binding Arrival_date_time}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <Rectangle Grid.Column="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" VerticalAlignment="Stretch"/>

                <!-- Available rooms -->
                <StackPanel Grid.Column="2" Spacing="8">
                    <TextBlock Text="Available Rooms" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Select a room for manual assignment" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ListView ItemsSource="{x:Bind ViewModel.AvailableRooms, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedRoom, Mode=TwoWay}"
                              SelectionMode="Single" MinHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorderStyle}" Margin="0,4">
                                    <Grid ColumnDefinitions="10,*" ColumnSpacing="10">
                                        <Rectangle Grid.Column="0" Width="6" RadiusX="3" RadiusY="3"
                                                   Fill="{Binding Room_Type, Converter={StaticResource RoomTypeColorConverter}}"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Room_Type}" FontWeight="SemiBold"/>
                                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}">
                                                <Run Text="Room #"/><Run Text="{Binding Room_ID}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>

            <!-- Action buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Auto-Assign Room" Command="{x:Bind ViewModel.AssignRoomCommand}"/>
                <Button Content="Manual Assign" Command="{x:Bind ViewModel.ManualAssignRoomCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- ── RIGHT: Visit Details Panel ── -->
        <Border Grid.Column="1"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,0,0,0">
            <local:VisitDetailsPanel x:Name="DetailsPanel"
                                     Patient="{x:Bind ViewModel.SelectedPatient, Mode=OneWay}"
                                     Visit="{x:Bind ViewModel.SelectedVisit, Mode=OneWay}"
                                     Triage="{x:Bind ViewModel.SelectedTriage, Mode=OneWay}"/>
        </Border>

    </Grid>
</Page>
